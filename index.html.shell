<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mindvalley Events Hub</title>
  <link rel="stylesheet" href="shell.css">
</head>
<body>
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <span class="sidebar-logo">MV</span>
      <span class="sidebar-title">Events Hub</span>
      <button class="sidebar-close" id="sidebarClose">&times;</button>
    </div>

    <a class="nav-item active" data-view="views/global/index.html" id="navGlobal">
      <span class="nav-icon">📊</span>
      <span class="nav-label">All Events</span>
    </a>

    <div class="nav-section">Event Dashboards</div>
    <div id="eventNavItems"></div>
  </nav>

  <button class="hamburger" id="hamburger">☰</button>

  <main class="content">
    <iframe id="contentFrame" src="views/global/index.html"></iframe>
  </main>

  <script src="shell.js"></script>
</body>
</html>
